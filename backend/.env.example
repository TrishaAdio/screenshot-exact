# Copy to .env and fill in values.
PORT=5000
NODE_ENV=production

# MongoDB connection string. If empty, server.js will prompt at startup.
MONGODB_URI=

# JWT — use a long random string (32+ chars).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — comma-separated origins, or * for all.
# In production, set to your real frontend origin(s).
CORS_ORIGIN=*

# Reverse proxy / load balancer hops to trust for req.ip and rate limiting.
# Use 1 for a typical VPS setup behind Nginx, ngrok, or another single proxy.
TRUST_PROXY=1
